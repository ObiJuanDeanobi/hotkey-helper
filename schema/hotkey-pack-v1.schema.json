{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hotkey-helper/hotkey-helper/blob/main/schema/hotkey-pack-v1.schema.json",
  "title": "Hotkey Helper Pack",
  "description": "A data-only, human-editable collection of keyboard shortcuts for one application.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "version",
    "description",
    "license",
    "match",
    "metadata",
    "shortcuts"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "minLength": 3,
      "maxLength": 128
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "license": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "match": {
      "$ref": "#/$defs/match"
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "shortcuts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/shortcut"
      }
    }
  },
  "$defs": {
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "desktopIds",
        "windowClasses"
      ],
      "properties": {
        "desktopIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        },
        "windowClasses": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "homepage",
        "sources"
      ],
      "properties": {
        "homepage": {
          "type": "string",
          "format": "uri",
          "pattern": "^https?://"
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/source"
          }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "url",
        "verifiedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "minLength": 1,
          "maxLength": 80
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https?://"
        },
        "verifiedAt": {
          "type": "string",
          "format": "date",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "applicationVersion": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        }
      }
    },
    "shortcut": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "action",
        "keys",
        "category",
        "sourceId"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "minLength": 1,
          "maxLength": 80
        },
        "action": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "keys": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          }
        },
        "category": {
          "type": "string",
          "minLength": 1,
          "maxLength": 60
        },
        "sourceId": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        }
      }
    }
  }
}
